{
  "name": "publish",
  "description": "GitHub Action for TestBeats",
  "version": "1.0.1",
  "author": "step-security",
  "private": true,
  "homepage": "https://github.com/step-security/test-results-reporter-publish#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/step-security/test-results-reporter-publish.git"
  },
  "bugs": {
    "url": "https://github.com/step-security/test-results-reporter-publish/issues"
  },
  "keywords": [
    "actions",
    "node",
    "setup"
  ],
  "exports": {
    ".": "./dist/index.js"
  },
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "bundle": "npm run format:write && npm run package",
    "ci-test": "jest",
    "coverage": "make-coverage-badge --output-path ./badges/coverage.svg",
    "format:write": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint . -c ./eslint.config.mjs",
    "local-action": "local-action . src/main.ts .env",
    "package": "ncc build src/index.ts -o dist --source-map --license licenses.txt",
    "package:watch": "npm run package -- --watch",
    "test": "jest",
    "all": "npm run format:write && npm run lint && npm run test && npm run coverage && npm run package"
  },
  "license": "MIT",
  "jest": {
    "preset": "ts-jest",
    "verbose": true,
    "clearMocks": true,
    "testEnvironment": "node",
    "moduleFileExtensions": [
      "js",
      "ts"
    ],
    "testMatch": [
      "**/*.test.ts"
    ],
    "testPathIgnorePatterns": [
      "/node_modules/",
      "/dist/"
    ],
    "transform": {
      "^.+\\.ts$": "ts-jest"
    },
    "coverageReporters": [
      "json-summary",
      "text",
      "lcov"
    ],
    "collectCoverage": true,
    "collectCoverageFrom": [
      "./src/**"
    ],
    "reporters": [
      "default",
      [
        "jest-junit",
        {
          "suiteName": "TestBeats Publish GHA Tests",
          "outputDirectory": "./reports",
          "outputName": "junit.xml"
        }
      ]
    ]
  },
  "dependencies": {
    "@actions/core": "^1.11.1",
    "axios": "^1.18.1"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.1",
    "@eslint/js": "^9.28.0",
    "@github/local-action": "^2.6.2",
    "@types/jest": "^29.5.0",
    "@types/node": "^24.0.3",
    "@typescript-eslint/eslint-plugin": "^8.33.1",
    "@typescript-eslint/parser": "^8.33.1",
    "@vercel/ncc": "^0.38.3",
    "eslint": "^9.28.0",
    "eslint-plugin-jest": "^28.12.0",
    "globals": "^16.2.0",
    "jest": "^29.5.0",
    "jest-junit": "^16.0.0",
    "make-coverage-badge": "^1.2.0",
    "prettier": "^3.5.3",
    "ts-jest": "^29.3.4",
    "typescript": "^5.8.3"
  }
}
